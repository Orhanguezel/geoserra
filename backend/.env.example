# =============================================================
# GeoSerra Backend — .env.example
# Kopyala: cp .env.example .env
# =============================================================

# Genel
PORT=8095
NODE_ENV=development

# =============================================================
# DB
# =============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=geoserra

# Seed / migration için ayrı admin kullanıcı bilgisi.
# Tanımlanmazsa DB_USER / DB_PASSWORD kullanılır.
DB_ADMIN_HOST=localhost
DB_ADMIN_PORT=3306
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=

# =============================================================
# Auth / JWT
# =============================================================
JWT_SECRET=change-me-to-random-string-min-32-chars
COOKIE_SECRET=change-me-to-long-random-string-min-32-chars

# Seed için admin hesabı
ADMIN_EMAIL=admin@geoserra.com
ADMIN_ID=00000000-0000-0000-0000-000000000001
ADMIN_PASSWORD=change-me-strong-password

# Auth modülü — admin email allowlist (virgülle ayrılmış)
AUTH_ADMIN_EMAILS=admin@geoserra.com

# =============================================================
# CORS
# =============================================================
CORS_ORIGIN=http://localhost:3071,http://localhost:3072

# =============================================================
# URL'ler
# =============================================================
PUBLIC_URL=http://localhost:8095
FRONTEND_URL=http://localhost:3071
ADMIN_URL=http://localhost:3072

# =============================================================
# Mail / SMTP
# =============================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@geoserra.com
SMTP_PASS=your-smtp-password
MAIL_FROM=GeoSerra <noreply@geoserra.com>

# =============================================================
# Stripe
# =============================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# =============================================================
# PayPal
# =============================================================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# =============================================================
# ExchangeRate API (open.er-api.com — ücretsiz, key gereksiz)
# =============================================================
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
EXCHANGE_RATE_CACHE_TTL_SECONDS=3600

# =============================================================
# Python Analiz Scriptleri
# =============================================================
PYTHON_BIN=python3
PYTHON_SCRIPTS_DIR=./python

# Google PageSpeed Insights API Key (ücretsiz, 25k/gün limiti var)
GOOGLE_PSI_API_KEY=

# Merkezi Scrapling servisi (opsiyonel)
# SCRAPER_ENABLED=false ise eski fetch_page.py davranışı korunur.
# true olduğunda servis denenir; hata alırsa legacy Python fallback çalışır.
SCRAPER_ENABLED=false
SCRAPER_URL=http://localhost:8200
SCRAPER_API_KEY=scraper-geoserra-change-me
SCRAPER_TIMEOUT_MS=90000

# Google OAuth — Sign-in with Google (id_token aud doğrulaması için)
GOOGLE_CLIENT_ID=

# =============================================================
# AI / LLM — Sadece ücretli analizde kullanılır (ücretsizde devreye girmez)
# Groq: https://console.groq.com → API Keys → Create Key
# Model önerisi: llama-3.3-70b-versatile (hızlı, ücretsiz tier mevcut)
# Maliyet: rapor başına ~$0.003–0.008 (Groq paid tier)
# =============================================================
GROQ_API_KEY=gsk_...
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# =============================================================
# Storage (raporlar için)
# =============================================================
REPORTS_DIR=./storage/reports

# =============================================================
# Seed güvenlik
# =============================================================
ALLOW_DROP=false
