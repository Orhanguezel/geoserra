# =============================================================
# GeoSerra Backend — .env.example
# Kopyala: cp .env.example .env
# =============================================================

# Genel
PORT=8095
NODE_ENV=development

# =============================================================
# DB
# =============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=geoserra

# =============================================================
# Auth / JWT
# =============================================================
JWT_SECRET=change-me-to-random-string-min-32-chars
COOKIE_SECRET=change-me-to-long-random-string-min-32-chars

# Seed için admin hesabı
ADMIN_EMAIL=admin@geoserra.com
ADMIN_ID=00000000-0000-0000-0000-000000000001
ADMIN_PASSWORD=change-me-strong-password

# Auth modülü — admin email allowlist (virgülle ayrılmış)
AUTH_ADMIN_EMAILS=admin@geoserra.com

# =============================================================
# CORS
# =============================================================
CORS_ORIGIN=http://localhost:3071,http://localhost:3072

# =============================================================
# URL'ler
# =============================================================
PUBLIC_URL=http://localhost:8095
FRONTEND_URL=http://localhost:3071
ADMIN_URL=http://localhost:3072

# =============================================================
# Mail / SMTP
# =============================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@geoserra.com
SMTP_PASS=your-smtp-password
MAIL_FROM=GeoSerra <noreply@geoserra.com>

# =============================================================
# Stripe
# =============================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# =============================================================
# PayPal
# =============================================================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# =============================================================
# ExchangeRate API (open.er-api.com — ücretsiz, key gereksiz)
# =============================================================
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
EXCHANGE_RATE_CACHE_TTL_SECONDS=3600

# =============================================================
# Python Analiz Scriptleri
# =============================================================
PYTHON_BIN=python3
PYTHON_SCRIPTS_DIR=./python

# Google PageSpeed Insights API Key (ücretsiz, 25k/gün limiti var)
GOOGLE_PSI_API_KEY=

# =============================================================
# Storage (raporlar için)
# =============================================================
REPORTS_DIR=./storage/reports

# =============================================================
# Seed güvenlik
# =============================================================
ALLOW_DROP=false
