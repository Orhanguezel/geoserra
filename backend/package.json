{
  "name": "geoserra-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun x tsc -p tsconfig.json && bun x tsc-alias -p tsconfig.json && node scripts/fix-esm-extensions.mjs",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "start:bun": "bun dist/index.js",
    "db:seed": "bun run db:seed:nodrop",
    "db:seed:fresh": "bun run build && node --experimental-specifier-resolution=node dist/db/seed/index.js",
    "db:seed:nodrop": "bun run build && node --experimental-specifier-resolution=node dist/db/seed/index.js --no-drop",
    "db:seed:only": "bun run build && node --experimental-specifier-resolution=node dist/db/seed/index.js --only=",
    "scraper:compare": "bun run scripts/compare-scrapers.ts --urls=scripts/scraper-test-urls.txt --output=diff-report.json"
  },
  "dependencies": {
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10",
    "@fastify/multipart": "^9",
    "@fastify/mysql": "^5.0.2",
    "@fastify/rate-limit": "^10",
    "@fastify/static": "^8.3.0",
    "@vps/shared-backend": "workspace:*",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.6",
    "fastify": "^5",
    "fastify-plugin": "^5.1.0",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.11",
    "stripe": "^17.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "20",
    "@types/nodemailer": "^7.0.4",
    "bun-types": "^1.3.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "5"
  }
}
